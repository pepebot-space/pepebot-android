<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_card_surface">

    <!-- Fixed Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="#151515">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_config"
            app:tint="@color/pepebot_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pepebot Configuration"
            android:textColor="@color/pepebot_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/pepebot_outline" />

    <!-- Scrollable Form Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginEnd="-8dp"
        android:layout_marginRight="-8dp"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Provider Setup"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/pepebot_on_surface"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:text="Choose your primary AI Provider:"
                android:textColor="@color/pepebot_text_secondary"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spinner_provider"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_edittext"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:popupBackground="#2A2A2A"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API Key:"
                android:textSize="13sp"
                android:textColor="@color/pepebot_text_secondary"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter API Key"
                android:inputType="textPassword"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textColor="@color/pepebot_on_surface"
                android:textColorHint="#777777"
                android:layout_marginBottom="24dp" />


            <!-- Chat Channels -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat Channels"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/pepebot_on_surface"
                android:layout_marginBottom="8dp" />

            <!-- Telegram -->
            <CheckBox
                android:id="@+id/cb_telegram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/pepebot_on_surface"
                android:text="Enable Telegram Bot" />

            <EditText
                android:id="@+id/et_telegram_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Telegram Bot Token"
                android:inputType="textPassword"
                android:visibility="gone"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textColor="@color/pepebot_on_surface"
                android:textColorHint="#777777"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="32dp"/>

            <!-- Discord -->
            <CheckBox
                android:id="@+id/cb_discord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/pepebot_on_surface"
                android:text="Enable Discord Bot" />

            <EditText
                android:id="@+id/et_discord_token"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Discord Bot Token"
                android:inputType="textPassword"
                android:visibility="gone"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textColor="@color/pepebot_on_surface"
                android:textColorHint="#777777"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="32dp"/>

            <!-- WhatsApp -->
            <CheckBox
                android:id="@+id/cb_whatsapp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enable WhatsApp Bridge"
                android:textColor="@color/pepebot_on_surface"
                android:textSize="13sp"
                android:layout_marginBottom="16dp"/>

            <!-- Tools Configuration -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tools Integration"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/pepebot_on_surface"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Brave Search API Key:"
                android:textSize="13sp"
                android:textColor="@color/pepebot_text_secondary"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Get it at: https://search.brave.com/api"
                android:textSize="12sp"
                android:textColor="#b3b0b0ff"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_brave_api_key"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Brave Search API Key"
                android:inputType="textPassword"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textColor="@color/pepebot_on_surface"
                android:textColorHint="#777777"
                android:layout_marginBottom="24dp" />

            <!-- Agent Configuration -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agent Settings"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/pepebot_on_surface"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:text="Temperature (0.0 - 1.0):"
                android:textColor="@color/pepebot_text_secondary"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0.7"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textColor="@color/pepebot_on_surface"
                android:textColorHint="#777777"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Tool Iterations:"
                android:textSize="13sp"
                android:textColor="@color/pepebot_text_secondary"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_max_iterations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="20"
                android:inputType="number"
                android:background="@drawable/bg_edittext"
                android:padding="12dp"
                android:textColor="@color/pepebot_on_surface"
                android:textColorHint="#777777"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
